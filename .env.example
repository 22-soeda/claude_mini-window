# ─── Anthropic ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Claude model (optional – defaults to claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6

# ─── Notion MCP ───────────────────────────────────────────────────────────────
# Notion Integration Token (https://www.notion.so/my-integrations)
NOTION_API_KEY=secret_xxxxx

# Override the MCP command if needed (defaults shown below)
# NOTION_MCP_COMMAND=npx
# NOTION_MCP_ARGS=-y @notionhq/notion-mcp-server

# ─── Google Calendar MCP ──────────────────────────────────────────────────────
# OAuth 2.0 credentials from Google Cloud Console
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxx
GOOGLE_REFRESH_TOKEN=xxxxx

# Override the MCP command if needed (defaults shown below)
# GCAL_MCP_COMMAND=npx
# GCAL_MCP_ARGS=-y @google-labs/calendar-mcp
